---
import type { Member } from '../lib/types';
import { href } from '../lib/url';
interface Props { members: Member[]; }
const { members } = Astro.props;
---
<div class="wall">
  {members.map((m) => (
    <div class="wall__cell" title={m.name}>
      {m.logo ? <img src={href(m.logo)} alt={`${m.name} logo`} loading="lazy" /> : <span>{m.name}</span>}
    </div>
  ))}
</div>

<style>
  .wall {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  /* Keep columns as even divisors of the member count so rows stay full. */
  @media (max-width: 900px) { .wall { grid-template-columns: repeat(2, 1fr); } }
  /* Mobile: a compact 2-row horizontal carousel instead of a tall list */
  @media (max-width: 600px) {
    .wall {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-template-rows: repeat(2, 1fr);
      grid-auto-columns: 46%;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .wall::-webkit-scrollbar { display: none; }
    .wall__cell { scroll-snap-align: start; min-height: 92px; }
  }
  .wall__cell {
    background: var(--white);
    min-height: 104px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 22px 18px;
    transition: background 0.15s var(--ease);
  }
  .wall__cell:hover { background: var(--paper); }
  .wall__cell span {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--grey-400);
    transition: color 0.15s var(--ease);
  }
  .wall__cell:hover span { color: var(--blue); }
  .wall__cell img { max-height: 44px; width: auto; object-fit: contain; filter: grayscale(1); opacity: 0.8; }
  .wall__cell:hover img { filter: none; opacity: 1; }
</style>
