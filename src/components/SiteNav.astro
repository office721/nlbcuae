---
import Logo from './Logo.astro';
import { href } from '../lib/url';
import { primaryNav } from '../lib/nav';

interface Props {
  /** 'overlay' = transparent over a hero (homepage); 'solid' = paper bar */
  mode?: 'overlay' | 'solid';
}
const { mode = 'solid' } = Astro.props;
const current = Astro.url.pathname.replace(/\/$/, '');
---
<header class:list={['nav', `nav--${mode}`]} data-mode={mode} id="site-nav">
  <a href={href('/')} class="nav__logo" aria-label="NBC home">
    <Logo variant="horizontal" tone="light" height={34} class="navlogo navlogo--light" />
    <Logo variant="horizontal" tone="dark" height={34} class="navlogo navlogo--dark" />
  </a>

  <nav class="nav__links" aria-label="Primary">
    {primaryNav.map((item) => (
      <a
        href={href(item.path)}
        class="nav__link"
        aria-current={current.endsWith(item.path) ? 'page' : undefined}
      >{item.label}</a>
    ))}
  </nav>

  <a href={href('/membership')} class="nav__cta">Become a member</a>

  <button class="nav__burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" id="nav-burger">
    <span></span><span></span><span></span>
  </button>
</header>

<div class="mobile" id="mobile-menu" hidden>
  <nav aria-label="Mobile">
    {primaryNav.map((item) => (
      <a href={href(item.path)} class="mobile__link">{item.label}</a>
    ))}
    <a href={href('/membership')} class="mobile__cta">Become a member</a>
  </nav>
</div>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 34px;
    padding: 18px clamp(20px, 5vw, 56px);
    transition: background 0.25s var(--ease), box-shadow 0.25s var(--ease),
      border-color 0.25s var(--ease);
    border-bottom: 1px solid transparent;
  }
  .nav__logo { display: inline-flex; margin-right: auto; }
  /* Swap logo colour with the nav state so the wordmark stays legible.
     :global() because the classes live on the child Logo component's svg. */
  :global(.navlogo) { display: block; }
  :global(.navlogo--dark) { display: none; }
  .nav--solid :global(.navlogo--light),
  .nav--overlay.is-scrolled :global(.navlogo--light) { display: none; }
  .nav--solid :global(.navlogo--dark),
  .nav--overlay.is-scrolled :global(.navlogo--dark) { display: block; }
  .nav__links { display: flex; gap: clamp(16px, 2vw, 30px); }
  .nav__link { font-size: 14.5px; font-weight: 500; position: relative; }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -5px;
    height: 2px;
    background: var(--orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease);
  }
  .nav__link:hover::after,
  .nav__link[aria-current='page']::after { transform: scaleX(1); }
  .nav__cta {
    background: var(--orange);
    color: var(--ink);
    font-weight: 600;
    font-size: 14px;
    padding: 9px 16px;
    border-radius: var(--radius);
    transition: background 0.15s var(--ease);
  }
  .nav__cta:hover { background: var(--orange-deep); }

  /* Overlay (transparent over hero) */
  .nav--overlay { background: transparent; }
  .nav--overlay .nav__link { color: #fff; opacity: 0.92; }
  .nav--overlay .nav__link:hover { opacity: 1; }

  /* Solid (paper bar) — also applied when overlay nav is scrolled */
  .nav--solid,
  .nav.is-scrolled {
    background: rgba(250, 248, 245, 0.92);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--hairline);
    box-shadow: var(--shadow-sm);
  }
  .nav--solid .nav__link,
  .nav.is-scrolled .nav__link { color: var(--blue); opacity: 1; }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 6px;
  }
  .nav__burger span {
    width: 24px; height: 2px; background: var(--blue); border-radius: 2px;
    transition: background 0.2s var(--ease);
  }
  .nav--overlay .nav__burger span { background: #fff; }

  .mobile {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--blue-ink);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mobile[hidden] { display: none; }
  .mobile nav { display: flex; flex-direction: column; gap: 8px; text-align: center; }
  .mobile__link { color: #fff; font-size: 28px; font-weight: 500; padding: 10px; }
  .mobile__link:hover { color: var(--orange); }
  .mobile__cta {
    margin-top: 20px; background: var(--orange); color: var(--ink);
    font-weight: 600; padding: 14px 28px; border-radius: var(--radius);
  }

  @media (max-width: 880px) {
    .nav__links, .nav__cta { display: none; }
    .nav__burger { display: flex; }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  if (nav?.dataset.mode === 'overlay') {
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const burger = document.getElementById('nav-burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = menu?.hasAttribute('hidden');
    if (open) menu?.removeAttribute('hidden');
    else menu?.setAttribute('hidden', '');
    burger.setAttribute('aria-expanded', String(!!open));
    document.body.style.overflow = open ? 'hidden' : '';
  });
</script>
