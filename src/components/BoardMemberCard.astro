---
import type { BoardMember } from '../lib/types';
interface Props { member: BoardMember; }
const { member } = Astro.props;
const initials = member.name
  .split(' ')
  .map((n) => n[0])
  .slice(0, 2)
  .join('');
---
<article class="bm">
  <div class="bm__photo">
    {member.photo
      ? <img src={member.photo} alt={member.name} loading="lazy" />
      : <span class="bm__initials">{initials}</span>}
  </div>
  <h3 class="bm__name">{member.name}</h3>
  <p class="bm__role">{member.role}</p>
  {member.company && <p class="bm__company">{member.company}</p>}
  {member.bio && <p class="bm__bio">{member.bio}</p>}
</article>

<style>
  .bm {
    background: var(--white);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 28px;
    text-align: center;
    transition: transform 0.15s var(--ease), box-shadow 0.15s var(--ease);
  }
  .bm:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
  .bm__photo {
    width: 96px; height: 96px; border-radius: 50%;
    margin: 0 auto 20px;
    background: linear-gradient(135deg, var(--blue), var(--blue-deep));
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .bm__photo img { width: 100%; height: 100%; object-fit: cover; }
  .bm__initials { font-size: 30px; font-weight: 600; color: #fff; letter-spacing: 0.02em; }
  .bm__name { font-size: 20px; font-weight: 500; margin-bottom: 6px; }
  .bm__role { font-size: 14px; color: var(--orange); font-weight: 600; }
  .bm__company { font-size: 14px; color: var(--grey-400); margin-top: 4px; }
  .bm__bio { font-size: 14px; line-height: 1.55; color: var(--ink); margin-top: 14px; }
</style>
