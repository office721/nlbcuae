---
import Button from './Button.astro';
import Container from './Container.astro';
import { href } from '../lib/url';
import { MEMBER_COUNT } from '../lib/members';
---
<section class="mcta">
  <Container>
    <div class="mcta__grid">
      <div>
        <p class="mcta__eyebrow">Membership</p>
        <h2 class="mcta__title">
          Join <span class="serif">{MEMBER_COUNT}</span> Dutch businesses already in the room.
        </h2>
        <p class="mcta__text">
          From global names to growing SMEs and startups, membership is your direct line to
          the Dutch business community in the UAE, the Consul General, and the Dubai Chambers
          network. We introduce you to the right people, then we get out of the way.
        </p>
      </div>
      <div class="mcta__actions">
        <ul class="mcta__list">
          <li>30+ events a year</li>
          <li>Market knowledge before you hit obstacles</li>
          <li>Advocacy with UAE &amp; Dutch authorities</li>
          <li>A directory of 170+ members</li>
        </ul>
        <Button href={href('/membership')} variant="primary">Become a member →</Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .mcta { background: var(--blue); color: #fff; padding: clamp(64px, 10vw, 110px) 0; }
  .mcta__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }
  .mcta__eyebrow {
    font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--orange); font-weight: 700; margin-bottom: 18px;
  }
  .mcta__title {
    font-size: clamp(30px, 3.6vw, 46px); color: #fff; line-height: 1.05;
    letter-spacing: -0.02em; margin-bottom: 20px;
  }
  .mcta__title .serif { color: var(--orange); }
  .mcta__text { color: rgba(255, 255, 255, 0.85); max-width: 540px; font-size: 16.5px; }
  .mcta__actions { display: flex; flex-direction: column; gap: 24px; align-items: flex-start; }
  .mcta__list { list-style: none; display: flex; flex-direction: column; gap: 12px; width: 100%; }
  .mcta__list li {
    padding: 12px 0; border-top: 1px solid rgba(255, 255, 255, 0.18);
    font-size: 15.5px; padding-left: 26px; position: relative;
  }
  .mcta__list li::before { content: '—'; position: absolute; left: 0; color: var(--orange); }
  @media (max-width: 820px) { .mcta__grid { grid-template-columns: 1fr; } }
</style>
