---
import Container from './Container.astro';
import { href } from '../lib/url';
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  image: string;
}
const { eyebrow, title, lede, image } = Astro.props;
const img = href(image);
---
<section class="phero" style={`--img: url('${img}')`}>
  <Container>
    <div class="phero__inner">
      {eyebrow && <p class="phero__eyebrow">{eyebrow}</p>}
      <h1 class="phero__title" set:html={title} />
      {lede && <p class="phero__lede">{lede}</p>}
    </div>
  </Container>
</section>

<style>
  .phero {
    position: relative;
    min-height: clamp(340px, 46vw, 520px);
    display: flex;
    align-items: flex-end;
    color: #fff;
    background-image:
      linear-gradient(180deg, rgba(9, 18, 40, 0.55) 0%, rgba(9, 18, 40, 0) 24%, rgba(9, 18, 40, 0) 42%, rgba(9, 18, 40, 0.82) 100%),
      linear-gradient(90deg, rgba(9, 18, 40, 0.5) 0%, rgba(9, 18, 40, 0.1) 60%),
      var(--img);
    background-size: cover;
    background-position: center;
  }
  .phero__inner {
    padding: clamp(36px, 6vh, 72px) 0;
    max-width: 760px;
  }
  .phero__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
    font-weight: 700;
    margin-bottom: 18px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .phero__eyebrow::before { content: ''; width: 30px; height: 2px; background: var(--orange); }
  .phero__title {
    color: #fff;
    text-shadow: 0 2px 26px rgba(0, 0, 0, 0.35);
    margin-bottom: 18px;
  }
  .phero__title :global(.serif) { color: var(--orange); }
  .phero__lede {
    font-size: clamp(17px, 2vw, 21px);
    line-height: 1.5;
    color: var(--on-dark-soft);
    max-width: 560px;
  }
  @media (max-width: 600px) {
    .phero__eyebrow { margin-bottom: 12px; }
    .phero__lede { font-size: 16px; }
  }
</style>
