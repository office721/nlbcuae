---
import Button from './Button.astro';
import { href } from '../lib/url';
const heroImg = href('/images/hero.jpg');
---
<section class="hero" style={`--hero-img: url('${heroImg}')`}>
  <div class="hero__inner">
    <p class="hero__eyebrow">Since 1997 · Dubai</p>
    <h1 class="hero__title">
      Doing business between two worlds, <span class="serif">made simpler.</span>
    </h1>
    <p class="hero__lede">
      For nearly three decades we have connected Dutch business with the UAE. We do it
      through events, introductions, and market knowledge that members actually use.
    </p>
    <div class="hero__cta">
      <Button href={href('/membership')} variant="primary">Become a member →</Button>
      <Button href={href('/events')} variant="ghost-light">See upcoming events</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    color: #fff;
    background-image:
      linear-gradient(180deg, rgba(9, 18, 40, 0.6) 0%, rgba(9, 18, 40, 0) 26%,
        rgba(9, 18, 40, 0) 44%, rgba(9, 18, 40, 0.82) 100%),
      var(--hero-img);
    background-size: cover;
    background-position: center;
  }
  .hero__inner {
    max-width: 860px;
    padding: 0 clamp(20px, 5vw, 56px) clamp(56px, 9vh, 96px);
  }
  .hero__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
    font-weight: 700;
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero__eyebrow::before {
    content: '';
    width: 32px;
    height: 2px;
    background: var(--orange);
  }
  .hero__title {
    font-size: clamp(40px, 6.4vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 24px;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
    max-width: 14ch;
  }
  .hero__title .serif { color: var(--orange); }
  .hero__lede {
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.55;
    color: var(--on-dark-soft);
    max-width: 540px;
    margin-bottom: 34px;
  }
  .hero__cta { display: flex; gap: 14px; flex-wrap: wrap; }
</style>
