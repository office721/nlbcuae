---
import type { NbcEvent } from '../lib/types';
import { href } from '../lib/url';
interface Props { event: NbcEvent; }
const { event } = Astro.props;
const d = new Date(event.startsAt);
const day = d.toLocaleDateString('en-GB', { day: '2-digit' });
const month = d.toLocaleDateString('en-GB', { month: 'short' });
const time = d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
const img = event.image ? href(event.image) : null;
---
<a href={href(`/events/${event.slug}`)} class="ev">
  <div class="ev__media" style={img ? `--img: url('${img}')` : undefined}>
    <span class="ev__date">
      <span class="ev__day">{day}</span>
      <span class="ev__month">{month}</span>
    </span>
    <span class="ev__type">{event.type}</span>
  </div>
  <div class="ev__body">
    <h3 class="ev__title">{event.title}</h3>
    <p class="ev__meta">
      <svg class="ev__pin" viewBox="0 0 16 16" aria-hidden="true" width="13" height="13"><path fill="currentColor" d="M8 0a5 5 0 0 0-5 5c0 3.5 5 11 5 11s5-7.5 5-11a5 5 0 0 0-5-5Zm0 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/></svg>
      {event.location} · {time}
    </p>
    <p class="ev__summary">{event.summary}</p>
    <span class="ev__more">View details →</span>
  </div>
</a>

<style>
  .ev {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.18s var(--ease), box-shadow 0.18s var(--ease), border-color 0.18s var(--ease);
    height: 100%;
  }
  .ev:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: transparent;
  }

  .ev__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background-color: var(--blue);
    background-image:
      linear-gradient(180deg, rgba(10, 18, 40, 0.05) 40%, rgba(10, 18, 40, 0.35) 100%),
      var(--img, linear-gradient(135deg, var(--blue), var(--blue-deep)));
    background-size: cover;
    background-position: center;
  }
  .ev:hover .ev__media { background-size: 104%; }

  .ev__date {
    position: absolute;
    top: 14px;
    left: 14px;
    width: 58px;
    height: 58px;
    border-radius: var(--radius);
    background: var(--white);
    color: var(--blue);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
    box-shadow: var(--shadow-sm);
  }
  .ev__day { font-size: 23px; font-weight: 700; }
  .ev__month { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 3px; font-weight: 600; }

  .ev__type {
    position: absolute;
    bottom: 14px;
    left: 14px;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 700;
    background: var(--orange);
    padding: 5px 10px;
    border-radius: 99px;
  }

  .ev__body { padding: 22px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .ev__title { font-size: 19px; font-weight: 500; color: var(--ink); letter-spacing: -0.01em; line-height: 1.2; }
  .ev__meta {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--grey-400);
  }
  .ev__pin { color: var(--orange); flex: none; }
  .ev__summary { font-size: 14.5px; line-height: 1.5; color: var(--ink); }
  .ev__more { font-size: 14px; font-weight: 600; color: var(--blue); margin-top: auto; padding-top: 6px; }
</style>
