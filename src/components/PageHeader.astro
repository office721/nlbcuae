---
import Container from './Container.astro';
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---
<header class="ph">
  <Container>
    {eyebrow && <p class="ph__eyebrow">{eyebrow}</p>}
    <h1 class="ph__title" set:html={title} />
    {lede && <p class="ph__lede">{lede}</p>}
  </Container>
</header>

<style>
  .ph {
    background: var(--paper);
    padding: clamp(48px, 8vw, 90px) 0 clamp(32px, 5vw, 56px);
    border-bottom: 1px solid var(--hairline);
  }
  .ph__eyebrow {
    font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--grey-400); font-weight: 600; margin-bottom: 18px;
    display: inline-flex; align-items: center; gap: 12px;
  }
  .ph__eyebrow::before { content: ''; width: 30px; height: 2px; background: var(--orange); }
  .ph__title { max-width: 16ch; }
  .ph__title :global(.serif) { color: var(--orange); }
  .ph__lede {
    font-size: clamp(18px, 2vw, 22px); line-height: 1.5; color: var(--ink);
    max-width: 640px; margin-top: 24px;
  }
  @media (max-width: 600px) {
    .ph { padding: 36px 0 26px; }
    .ph__eyebrow { margin-bottom: 14px; }
    .ph__lede { font-size: 16px; margin-top: 16px; }
  }
</style>
