---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import PageHeader from '../components/PageHeader.astro';
import { CONTACT } from '../lib/nav';

// Static hosting: post to a configurable form endpoint (e.g. Formspree).
// If none is set, the form falls back to a mailto: link.
const endpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT ?? '';
const usesMailto = !endpoint;
---
<BaseLayout title="Contact" description="Get in touch with the Netherlands Business Council UAE. Email, phone, and our office in Dubai.">
  <PageHeader
    eyebrow="Contact"
    title='Let us start <span class="serif">a conversation.</span>'
    lede="Questions about membership, events, or partnership? Send us a message and we will get back to you."
  />

  <section class="contact">
    <Container>
      <div class="contact__grid">
        <div class="contact__details">
          <h2 class="contact__h">Get in touch</h2>
          <ul class="contact__list">
            <li>
              <span class="contact__label">Email</span>
              <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
            </li>
            <li>
              <span class="contact__label">Phone</span>
              <a href={`tel:${CONTACT.phone.replace(/\s/g, '')}`}>{CONTACT.phone}</a>
            </li>
            <li>
              <span class="contact__label">Office</span>
              <span>{CONTACT.poBox}</span>
            </li>
            <li>
              <span class="contact__label">Follow</span>
              <span class="contact__social">
                <a href={CONTACT.linkedin} target="_blank" rel="noopener">LinkedIn</a>
                <a href={CONTACT.facebook} target="_blank" rel="noopener">Facebook</a>
                <a href={CONTACT.instagram} target="_blank" rel="noopener">Instagram</a>
              </span>
            </li>
          </ul>

          <div class="contact__map">
            <iframe
              title="NBC office location in Dubai"
              src="https://www.openstreetmap.org/export/embed.html?bbox=55.20%2C25.15%2C55.35%2C25.25&layer=mapnik"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <div class="contact__formwrap">
          <form
            class="contact__form"
            method="post"
            action={usesMailto ? `mailto:${CONTACT.email}` : endpoint}
            enctype={usesMailto ? 'text/plain' : undefined}
          >
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="field">
              <label for="company">Company</label>
              <input id="company" name="company" type="text" autocomplete="organization" />
            </div>
            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="contact__submit">Send message</button>
            {usesMailto && (
              <p class="contact__hint">This opens your email app. Prefer to write directly? Email {CONTACT.email}.</p>
            )}
          </form>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .contact { padding: clamp(48px, 7vw, 90px) 0 clamp(56px, 9vw, 110px); }
  .contact__grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(32px, 5vw, 64px); }
  .contact__h { font-size: 24px; margin-bottom: 24px; }
  .contact__list { list-style: none; display: flex; flex-direction: column; }
  .contact__list li { display: flex; flex-direction: column; gap: 4px; padding: 16px 0; border-top: 1px solid var(--hairline); }
  .contact__list li:last-child { border-bottom: 1px solid var(--hairline); }
  .contact__label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--grey-400); font-weight: 600; }
  .contact__list a, .contact__list span:not(.contact__label) { font-size: 17px; color: var(--ink); }
  .contact__list a:hover { color: var(--blue); }
  .contact__social { display: flex; gap: 18px; }
  .contact__social a { color: var(--blue); font-weight: 500; }
  .contact__map { margin-top: 28px; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--hairline); }
  .contact__map iframe { width: 100%; height: 240px; border: 0; display: block; }

  .contact__formwrap { background: var(--white); border: 1px solid var(--hairline); border-radius: var(--radius-xl); padding: clamp(28px, 4vw, 44px); }
  .field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .field label { font-size: 13px; font-weight: 600; color: var(--ink); }
  .field input, .field textarea {
    font-family: var(--font-sans); font-size: 15px; padding: 13px 15px;
    border: 1px solid var(--grey-200); border-radius: var(--radius); background: var(--paper); color: var(--ink);
    resize: vertical;
  }
  .field input:focus-visible, .field textarea:focus-visible { outline: 2px solid var(--blue); border-color: var(--blue); }
  .contact__submit {
    font-family: var(--font-sans); font-size: 15px; font-weight: 600; cursor: pointer;
    background: var(--orange); color: var(--ink); border: 0; padding: 14px 26px; border-radius: var(--radius);
    transition: background 0.15s var(--ease);
  }
  .contact__submit:hover { background: var(--orange-deep); }
  .contact__hint { font-size: 13px; color: var(--grey-400); margin-top: 14px; }

  @media (max-width: 860px) { .contact__grid { grid-template-columns: 1fr; } }
</style>
