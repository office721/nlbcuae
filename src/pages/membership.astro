---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { href } from '../lib/url';
import { MEMBER_COUNT } from '../lib/members';
import { getMembershipTiers } from '../lib/membership';
import { getTestimonials } from '../lib/testimonials';

const tiers = await getMembershipTiers();
const testimonials = await getTestimonials();

const benefits = [
  { title: 'The right introductions', body: 'Meet founders, country heads, and managers who already do business in the UAE.' },
  { title: 'Events all year', body: 'More than 30 events a year, from networking nights to closed-door roundtables.' },
  { title: 'Market knowledge', body: 'Practical insight on licensing, hiring, and market entry before you hit obstacles.' },
  { title: 'A stronger voice', body: 'We represent Dutch business interests with UAE and Dutch authorities. You do not lobby alone.' },
  { title: 'Direct access', body: 'A direct line to the Dutch Consul General in Dubai and the Dubai Chambers network.' },
  { title: 'Visibility', body: 'A place in our member directory and the chance to be featured across our channels.' },
];

const steps = [
  { n: '01', t: 'Choose your membership', d: 'Pick the level that fits you or your company from the options above.' },
  { n: '02', t: 'Apply online', d: 'Complete the short application. We review and confirm your membership.' },
  { n: '03', t: 'Join the community', d: 'Get your welcome, your directory listing, and your first invitations.' },
];
---
<BaseLayout title="Become a Member" description="Join 170+ Dutch businesses in the UAE. Five membership levels from AED 1,000 a year. Introductions, events, market knowledge, and a stronger voice.">
  <PageHeader
    eyebrow="Membership"
    title='Join the room where Dutch business <span class="serif">happens.</span>'
    lede={`Membership connects you to ${MEMBER_COUNT} Dutch businesses in the UAE, the Consul General, and the Dubai Chambers network.`}
  />

  <section class="why">
    <Container>
      <SectionHeading eyebrow="Why join" title="What members get" />
      <div class="why__grid">
        {benefits.map((b) => (
          <article class="benefit">
            <h3 class="benefit__title">{b.title}</h3>
            <p class="benefit__body">{b.body}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="tiers">
    <Container>
      <SectionHeading eyebrow="Choose your level" title="Membership levels" />
      <p class="tiers__note">Annual membership. Choose the level that fits, then apply online.</p>
      <div class="tiers__grid">
        {tiers.map((t) => (
          <article class={`tier${t.featured ? ' tier--featured' : ''}`}>
            {t.featured && <span class="tier__badge">Most popular</span>}
            <h3 class="tier__name">{t.name}</h3>
            <p class="tier__price">{t.price} <span>{t.per}</span></p>
            <p class="tier__who">{t.who}</p>
            <a class="tier__apply" href={t.applyUrl} target="_blank" rel="noopener">Apply →</a>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="how">
    <Container>
      <SectionHeading eyebrow="How to join" title="Three simple steps" />
      <ol class="how__list">
        {steps.map((s) => (
          <li class="step">
            <span class="step__n serif">{s.n}</span>
            <div>
              <h3 class="step__t">{s.t}</h3>
              <p class="step__d">{s.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </Container>
  </section>

  <section class="say">
    <Container>
      <SectionHeading eyebrow="What our members say" title="In their own words" />
      <div class="say__grid">
        {testimonials.map((item) => <TestimonialCard item={item} />)}
      </div>
    </Container>
  </section>

  <section class="join-cta">
    <Container>
      <div class="join-cta__inner">
        <h2 class="join-cta__title">Ready to join?</h2>
        <p class="join-cta__text">Pick your level above, or get in touch and we will guide you through it.</p>
        <Button href={href('/contact')} variant="primary">Get in touch →</Button>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .why { padding: clamp(48px, 7vw, 90px) 0; }
  .why__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 44px; }
  .benefit { background: var(--white); border: 1px solid var(--hairline); border-top: 3px solid var(--orange); border-radius: var(--radius-lg); padding: 28px; }
  .benefit__title { font-size: 19px; font-weight: 500; margin-bottom: 10px; }
  .benefit__body { font-size: 15px; line-height: 1.55; color: var(--ink); }

  .tiers { padding: clamp(48px, 7vw, 90px) 0; background: var(--paper); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  .tiers__note { margin: 18px 0 40px; color: var(--grey-400); font-size: 15px; }
  .tiers__grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  .tier { position: relative; background: var(--white); border: 1px solid var(--hairline); border-radius: var(--radius-lg); padding: 28px 22px; display: flex; flex-direction: column; }
  .tier--featured { border-color: var(--orange); border-width: 2px; box-shadow: var(--shadow); }
  .tier__badge { position: absolute; top: -11px; left: 22px; background: var(--orange); color: var(--ink); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; padding: 4px 10px; border-radius: 99px; }
  .tier__name { font-size: 20px; margin-bottom: 8px; }
  .tier__price { font-size: 22px; font-weight: 600; color: var(--blue); margin-bottom: 16px; }
  .tier__price span { font-size: 13px; font-weight: 400; color: var(--grey-400); }
  .tier__who { font-size: 14px; line-height: 1.5; color: var(--ink); margin-bottom: 22px; flex: 1; }
  .tier__apply { font-weight: 600; font-size: 15px; color: var(--blue); }
  .tier__apply:hover { color: var(--orange); }

  .how { padding: clamp(48px, 7vw, 90px) 0; }
  .how__list { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 44px; }
  .step { display: flex; gap: 16px; align-items: flex-start; }
  .step__n { font-size: 30px; color: var(--orange); line-height: 1; }
  .step__t { font-size: 19px; font-weight: 500; margin-bottom: 8px; }
  .step__d { font-size: 15px; line-height: 1.55; color: var(--ink); }

  .say { padding: clamp(48px, 7vw, 90px) 0; background: var(--paper); border-top: 1px solid var(--hairline); }
  .say__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 44px; }

  .join-cta { padding: clamp(56px, 8vw, 100px) 0; }
  .join-cta__inner { background: var(--blue); color: #fff; border-radius: var(--radius-xl); padding: clamp(40px, 6vw, 72px); text-align: center; }
  .join-cta__title { color: #fff; margin-bottom: 12px; }
  .join-cta__text { color: rgba(255,255,255,.85); margin: 0 auto 28px; max-width: 460px; }

  @media (max-width: 1000px) { .tiers__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 900px) {
    .why__grid, .how__list, .say__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) { .tiers__grid { grid-template-columns: 1fr; } }
</style>
