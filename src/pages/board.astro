---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BoardMemberCard from '../components/BoardMemberCard.astro';
import { getBoardMembers, getTeamMembers } from '../lib/board';
const board = await getBoardMembers();
const team = await getTeamMembers();
---
<BaseLayout navMode="overlay" title="Board & Team" description="The people who lead the Netherlands Business Council UAE: its board of directors and the team that runs the council day to day.">
  <PageHero
    eyebrow="Board & team"
    title='The people behind <span class="serif">the council.</span>'
    lede="NBC is led by a volunteer board of directors, supported by a small team that runs the council day to day."
    image="/images/heroes/board-hero.jpg"
    focus="center 28%"
  />

  <section class="people">
    <Container>
      <SectionHeading eyebrow="Leadership" title="Board of directors" />
      <div class="grid">
        {board.map((m) => <BoardMemberCard member={m} />)}
      </div>
    </Container>
  </section>

  <section class="people people--alt">
    <Container>
      <SectionHeading eyebrow="Day to day" title="The team" />
      <div class="grid grid--team">
        {team.map((m) => <BoardMemberCard member={m} />)}
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .people { padding: clamp(48px, 7vw, 90px) 0; }
  .people--alt { background: var(--paper); border-top: 1px solid var(--hairline); }
  .grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px;
  }
  .grid--team { grid-template-columns: repeat(2, 1fr); max-width: 720px; }
  @media (max-width: 820px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .grid, .grid--team { grid-template-columns: 1fr; } }
</style>
