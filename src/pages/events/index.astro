---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import EventCard from '../../components/EventCard.astro';
import PastEventsGallery from '../../components/PastEventsGallery.astro';
import { getUpcomingEvents } from '../../lib/events';
const upcoming = await getUpcomingEvents();
---
<BaseLayout navMode="overlay" title="Events" description="Networking nights, working breakfasts, roundtables, and the annual gala. See what is coming up at the Netherlands Business Council UAE.">
  <PageHero
    eyebrow="What's on"
    title='Where the Dutch business community <span class="serif">meets.</span>'
    lede="We run more than 30 events a year, from informal networking to closed-door roundtables. Members get the right people in the room."
    image="/images/events-hero.jpg"
  />

  <section class="ev-section">
    <Container>
      <SectionHeading eyebrow="Coming up" title="Upcoming events" />
      {upcoming.length > 0 ? (
        <div class="ev-grid">
          {upcoming.map((e) => <EventCard event={e} />)}
        </div>
      ) : (
        <p class="empty">No upcoming events are listed right now. Please check back soon.</p>
      )}
    </Container>
  </section>

  <div class="ev-past">
    <PastEventsGallery id="past" />
  </div>
</BaseLayout>

<style>
  .ev-section { padding: clamp(48px, 7vw, 90px) 0; }
  .ev-section--alt { background: var(--paper); border-top: 1px solid var(--hairline); }
  .ev-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px;
  }
  .empty { margin-top: 32px; color: var(--grey-400); font-size: 17px; }
  .ev-past { background: var(--paper); border-top: 1px solid var(--hairline); }
  @media (max-width: 980px) { .ev-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .ev-grid { grid-template-columns: 1fr; } }
</style>
