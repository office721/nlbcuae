---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import ChairVideo from '../components/ChairVideo.astro';
import PastEventsGallery from '../components/PastEventsGallery.astro';
import PillarCard from '../components/PillarCard.astro';
import EventCard from '../components/EventCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import MembershipCTA from '../components/MembershipCTA.astro';
import MemberLogoWall from '../components/MemberLogoWall.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { href } from '../lib/url';
import { getPillars } from '../lib/pillars';
import { getUpcomingEvents } from '../lib/events';
import { getRecentArticles } from '../lib/articles';
import { getCorporateMembers } from '../lib/members';
import { MEMBER_COUNT } from '../lib/members';

const pillars = await getPillars();
const events = await getUpcomingEvents(3);
const articles = await getRecentArticles(3);
const members = await getCorporateMembers();
---
<BaseLayout navMode="overlay">
  <Hero />

  <!-- 01b · Meet the Chair (video) -->
  <ChairVideo />

  <!-- 02 · What NBC is -->
  <section class="section section--blue">
    <Container>
      <div class="who__top">
        <div class="who__intro">
          <SectionHeading
            eyebrow="Who we are"
            title='A council connecting <span class="serif">two business cultures.</span>'
            tone="light"
          />
          <p class="who__lede">
            The Netherlands Business Council UAE is a non-profit, member-led organisation. Since
            1997 we have made business between the Netherlands and the UAE easier for our members
            and the wider Dutch business community. Everything we do rests on four pillars.
          </p>
        </div>
        <figure class="who__photo">
          <img src={href('/images/about-networking.jpg')} alt="NBC members networking at an event in Dubai" loading="lazy" width="1500" height="862" />
        </figure>
      </div>
      <div class="pillars">
        {pillars.map((p) => <PillarCard pillar={p} tone="dark" />)}
      </div>
    </Container>
  </section>

  <!-- 02b · Past events gallery (latest two; full set on the Events page) -->
  <PastEventsGallery limit={2} showAllHref={`${href('/events')}#past`} />

  <!-- 03 · Upcoming events -->
  <section class="section section--alt">
    <Container>
      <div class="section__head">
        <SectionHeading eyebrow="What's on" title="Upcoming events" />
        <Button href={href('/events')} variant="ghost">All events →</Button>
      </div>
      <div class="ev-grid">
        {events.map((e) => <EventCard event={e} />)}
      </div>
    </Container>
  </section>

  <!-- 04 · Membership -->
  <MembershipCTA />

  <!-- 05 · Member directory teaser -->
  <section class="section">
    <Container>
      <div class="directory">
        <div>
          <SectionHeading eyebrow="The community" title={`${MEMBER_COUNT} members and growing`} />
          <p class="section__lede">
            Well-known Dutch companies such as Air France-KLM, ING, Van Oord, Boskalis, Fugro
            and Royal IHC, alongside SMEs and startups building their UAE presence.
          </p>
          <Button href={href('/membership')} variant="ghost">Explore membership →</Button>
        </div>
      </div>
      <div class="wall-wrap">
        <MemberLogoWall members={members} />
      </div>
    </Container>
  </section>

  <!-- 06 · Latest news -->
  <section class="section section--alt">
    <Container>
      <div class="section__head">
        <SectionHeading eyebrow="News & insight" title="Latest from the council" />
        <Button href={href('/news')} variant="ghost">All news →</Button>
      </div>
      <div class="art-grid">
        {articles.map((a) => <ArticleCard article={a} />)}
      </div>
    </Container>
  </section>

  <!-- 07 · Newsletter -->
  <NewsletterSignup />
</BaseLayout>

<style>
  .section { padding: clamp(64px, 9vw, 110px) 0; }
  .section--alt { background: var(--paper); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  .section--blue { background: var(--blue); color: #fff; }
  .who__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  .who__lede {
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 24px;
    max-width: 520px;
  }
  .who__photo { margin: 0; }
  .who__photo img {
    width: 100%;
    height: clamp(240px, 28vw, 360px);
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    display: block;
  }
  .section--blue .pillars {
    margin-top: clamp(44px, 6vw, 68px);
    padding-top: clamp(40px, 5vw, 56px);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
  }
  .section__lede {
    font-size: clamp(17px, 1.8vw, 20px); line-height: 1.5; color: var(--ink);
    max-width: 640px; margin: 24px 0 0;
  }
  .section__head {
    display: flex; justify-content: space-between; align-items: flex-end;
    gap: 24px; margin-bottom: 40px; flex-wrap: wrap;
  }
  .pillars {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 32px; margin-top: 56px;
  }
  .ev-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .art-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .directory { margin-bottom: 40px; }
  .wall-wrap { margin-top: 8px; }

  @media (max-width: 980px) {
    .pillars { grid-template-columns: repeat(2, 1fr); gap: 28px; }
    .ev-grid, .art-grid { grid-template-columns: repeat(2, 1fr); }
    .who__top { grid-template-columns: 1fr; }
    .who__lede { max-width: none; }
  }
  /* Mobile: swipeable carousels instead of a long vertical scroll */
  @media (max-width: 768px) {
    .ev-grid, .art-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 16px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .ev-grid::-webkit-scrollbar,
    .art-grid::-webkit-scrollbar { display: none; }
    /* :global() because the cards live in their own component scope */
    .ev-grid > :global(.ev),
    .art-grid > :global(.art) { flex: 0 0 80%; scroll-snap-align: start; }
  }
  @media (max-width: 600px) {
    .section { padding: 44px 0; }
    .section__lede { font-size: 16px; margin-top: 16px; }
    .section__head { margin-bottom: 26px; }
    .pillars { grid-template-columns: 1fr; gap: 16px; margin-top: 30px; }
    .directory { margin-bottom: 28px; }
    .wall-wrap { margin-top: 0; }
    .who__lede { font-size: 16px; margin-top: 16px; }
    .section--blue .pillars { margin-top: 26px; padding-top: 26px; }
  }
</style>
