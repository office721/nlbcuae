# Copy to .env and fill in. Never commit your real .env.

# Contact form: a Formspree-style endpoint that accepts POSTed form fields.
# If unset, the contact form falls back to a mailto: link.
PUBLIC_CONTACT_FORM_ENDPOINT=

# Newsletter signup endpoint (Phase 2 / optional).
PUBLIC_NEWSLETTER_ENDPOINT=

# GlueUp API (Phase 2 — do not commit real values).
GLUEUP_API_KEY=
GLUEUP_API_SECRET=
GLUEUP_BASE_URL=
